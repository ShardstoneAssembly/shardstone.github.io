---
layout: base.njk
title: Skullbox — Shardstone Assembly
---

<main class="product-page">

  <!-- Full-screen hero with background art -->
  <section
    class="product-hero"
    style="{% if skullbox.hero_bg %}background-image: url('{{ skullbox.hero_bg }}');{% endif %}"
  >
    <div class="product-hero-content">
      <h1 class="product-title">{{ skullbox.title }}</h1>
      {% if skullbox.subtitle %}
      <p class="product-subtitle">{{ skullbox.subtitle }}</p>
      {% endif %}
    </div>
  </section>

  <!-- Description + cover image -->
  <section class="product-content">
    <div class="product-content-inner">

      <div class="product-text">
        {% if skullbox.eyebrow %}
        <p class="eyebrow">{{ skullbox.eyebrow }}</p>
        {% endif %}
        <div class="rich-text">
          {{ skullbox.description | markdown | safe }}
        </div>
        {% if skullbox.buy_url %}
        <a href="{{ skullbox.buy_url }}" class="btn" target="_blank" rel="noopener noreferrer">
          {{ skullbox.buy_text if skullbox.buy_text else "Buy Now" }}
        </a>
        {% endif %}
      </div>

      {% if skullbox.cover_image %}
      <div class="product-cover">
        <img src="{{ skullbox.cover_image }}" alt="{{ skullbox.title }}">
      </div>
      {% endif %}

    </div>
  </section>

  <!-- Screenshot gallery -->
  {% if skullbox.gallery and skullbox.gallery.length %}
  <section class="gallery">
    <div class="gallery-grid">
      {% for item in skullbox.gallery %}
      <div class="gallery-item">
        <img src="{{ item.image }}" alt="Skullbox screenshot">
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

</main>
