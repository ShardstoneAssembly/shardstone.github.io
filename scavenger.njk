---
layout: base.njk
title: Scavenger — Shardstone Assembly
---

<main class="product-page" style="--hero-bg: url('{{ scavenger.hero_bg }}');">

  <header class="product-page-header">
    {% if scavenger.title_logo %}
      <img src="{{ scavenger.title_logo }}" alt="{{ scavenger.title }}" class="product-title-logo">
    {% else %}
      <h1 class="product-title" {% if scavenger.title_color %}style="color: {{ scavenger.title_color }}"{% endif %}>{{ scavenger.title }}</h1>
    {% endif %}
    {% if scavenger.subtitle %}
    <p class="product-subtitle">{{ scavenger.subtitle }}</p>
    {% endif %}
  </header>

  <div class="product-page-body">

    <section class="product-entry" {% if scavenger.text_color %}style="color: {{ scavenger.text_color }}"{% endif %}>
      <div class="product-entry-inner">
        <div class="product-text">
          {% if scavenger.eyebrow %}<p class="eyebrow">{{ scavenger.eyebrow }}</p>{% endif %}
          <div class="rich-text">{{ scavenger.description | markdown | safe }}</div>
          <div class="product-buttons">
            {% if scavenger.buttons and scavenger.buttons.length %}
              {% for btn in scavenger.buttons %}<a href="{{ btn.url }}" class="btn" target="_blank" rel="noopener noreferrer">{{ btn.text }}</a>{% endfor %}
            {% elif scavenger.buy_url %}
              <a href="{{ scavenger.buy_url }}" class="btn" target="_blank" rel="noopener noreferrer">{{ scavenger.buy_text if scavenger.buy_text else "Buy Now" }}</a>
            {% endif %}
          </div>
        </div>
        {% if scavenger.cover_image %}
        <div class="product-cover">
          {% if scavenger.cover_link %}<a href="{{ scavenger.cover_link }}" target="_blank" rel="noopener noreferrer">{% endif %}
          <img src="{{ scavenger.cover_image }}" alt="{{ scavenger.title }}">
          {% if scavenger.cover_link %}</a>{% endif %}
        </div>
        {% endif %}
      </div>
    </section>

    {% if scavenger.gallery and scavenger.gallery.length %}
    <section class="gallery">
      <div class="gallery-grid">
        {% for item in scavenger.gallery %}<div class="gallery-item"><img src="{{ item.image }}" alt="Screenshot" loading="lazy"></div>{% endfor %}
      </div>
    </section>
    {% endif %}

    {% if scavenger.extra_products and scavenger.extra_products.length %}
      {% for ep in scavenger.extra_products %}
      <section class="product-entry product-entry--extra">
        <div class="product-entry-divider">
          {% if ep.title_logo %}<img src="{{ ep.title_logo }}" alt="{{ ep.title }}" class="product-title-logo product-title-logo--sm">
          {% else %}<h2 class="product-entry-title">{{ ep.title }}</h2>{% endif %}
        </div>
        <div class="product-entry-inner">
          <div class="product-text">
            {% if ep.eyebrow %}<p class="eyebrow">{{ ep.eyebrow }}</p>{% endif %}
            <div class="rich-text">{{ ep.description | markdown | safe }}</div>
            <div class="product-buttons">
              {% if ep.buttons and ep.buttons.length %}{% for btn in ep.buttons %}<a href="{{ btn.url }}" class="btn" target="_blank" rel="noopener noreferrer">{{ btn.text }}</a>{% endfor %}{% endif %}
            </div>
          </div>
          {% if ep.cover_image %}
          <div class="product-cover">
            {% if ep.cover_link %}<a href="{{ ep.cover_link }}" target="_blank" rel="noopener noreferrer">{% endif %}
            <img src="{{ ep.cover_image }}" alt="{{ ep.title }}">
            {% if ep.cover_link %}</a>{% endif %}
          </div>
          {% endif %}
        </div>
      </section>
      {% if ep.gallery and ep.gallery.length %}
      <section class="gallery">
        <div class="gallery-grid">
          {% for item in ep.gallery %}<div class="gallery-item"><img src="{{ item.image }}" alt="Screenshot" loading="lazy"></div>{% endfor %}
        </div>
      </section>
      {% endif %}
      {% endfor %}
    {% endif %}

  </div>
</main>

<div class="lightbox" id="lightbox" aria-hidden="true">
  <button class="lightbox-close" id="lightbox-close" aria-label="Close">×</button>
  <img src="" alt="" id="lightbox-img">
</div>

<script>
(function(){
  var lb=document.getElementById('lightbox'),img=document.getElementById('lightbox-img');
  document.querySelectorAll('.gallery-item img').forEach(function(i){
    i.addEventListener('click',function(){img.src=i.src;lb.classList.add('is-open');lb.setAttribute('aria-hidden','false');document.body.style.overflow='hidden';});
  });
  function close(){lb.classList.remove('is-open');lb.setAttribute('aria-hidden','true');document.body.style.overflow='';setTimeout(function(){img.src='';},300);}
  document.getElementById('lightbox-close').addEventListener('click',close);
  lb.addEventListener('click',function(e){if(e.target===lb)close();});
  document.addEventListener('keydown',function(e){if(e.key==='Escape')close();});
})();
</script>
